# 本番サイトURL（OG/Twitter画像等で使用）
# NEXT_PUBLIC_SITE_URL=https://mirinae.jp

# 開発時（SQLite）
DATABASE_URL="file:./prisma/dev.db"

# 퀴즈앱과 같은 PostgreSQL を使う場合、ここに 퀴즈앱 の接続文字列を設定
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Supabase + Vercel の場合：接続数制限エラーを防ぐため Transaction プーラー（ポート 6543）を使用
# Supabase ダッシュボード → Connect → Transaction を選択してコピー
# 例: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# 管理画面ログイン用パスワード（必須）。未設定ならログイン不可。
# ADMIN_PASSWORD=your-secret-password

# アクセス解析用（Supabase Dashboard > Settings > API で確認）
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
