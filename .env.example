# 本番サイトURL（OG/Twitter画像等で使用）
# NEXT_PUBLIC_SITE_URL=https://mirinae.jp

# 開発時（SQLite）
DATABASE_URL="file:./prisma/dev.db"

# 퀴즈앱과 같은 PostgreSQL を使う場合、ここに 퀴즈앱 の接続文字列を設定
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Supabase + Vercel の場合：接続数制限エラーを防ぐため Transaction プーラー（ポート 6543）を使用
# Supabase ダッシュボード → Connect → Transaction を選択してコピー
# 例: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# 管理画面ログイン用パスワード（必須）。未設定ならログイン不可。
# ADMIN_PASSWORD=your-secret-password

# 2段階認証（メールOTP）用。ADMIN_EMAIL + (Gmail または Resend) で OTP が必須になる。
# ADMIN_EMAIL=admin@example.com
# 推奨: 公開フォームと同じ Gmail（上の GMAIL_USER / GMAIL_APP_PASSWORD）
# 代替: Resend（未設定なら Gmail が使われる）
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Mirinae <noreply@mirinae.jp>
# 公開フォーム（trial / syutyu / netlesson）— Gmail SMTP（nodemailer）。Vercel に設定必須。
# SMTP ログイン用（個人アカウントでも可）
# GMAIL_USER=anirue@kaonnuri.com
# GMAIL_APP_PASSWORD=your_16_digit_app_password
# 受信者へ見える差出人（申込通知・自動返信の From）。未設定時は GMAIL_USER と同じ。
# 「別のアドレスから送信」に mirinae を追加済みであること。
# 追加しても anirue のまま見える場合は Gmail で mirinae を「デフォルトの送信元」に。
# FORM_MAIL_FROM=ミリネ韓国語教室 <mirinae@kaonnuri.com>
# 通知先（事務局の受信）。未設定時は GMAIL_USER、それも無ければ mirinae@kaonnuri.com
# FORM_NOTIFY_TO=mirinae@kaonnuri.com

# --- メールマガジン（/admin/newsletter /api/newsletter/*）---
# 配信・登録確認メールともに Resend を使用（NEWSLETTER_RESEND_FROM 未設定時は RESEND_FROM）
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=ミリネ <newsletter@your-resend-domain>
# NEWSLETTER_RESEND_FROM=ミリネ韓国語教室 <newsletter@your-resend-domain>
# 開封・解除リンク署名用（本番では強めのランダム文字列を設定）
# NEWSLETTER_TRACKING_SECRET=random-long-secret
# NEWSLETTER_UNSUB_SECRET=optional-second-secret
# Vercel Cron: /api/cron/newsletter（vercel.json）— 本番では CRON_SECRET または Vercel 付与の x-vercel-cron ヘッダ

# アクセス解析用（Supabase Dashboard > Settings > API で確認）
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
