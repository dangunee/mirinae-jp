// ミリネ管理画面：ホームページの表データ（個人・グループ等）
// 퀴즈앱과 같은 DB를 쓰려면 .env에 DATABASE_URL을 퀴즈앱과 동일하게 설정하세요.
// 예: DATABASE_URL="postgresql://user:pass@host:5432/dbname"

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  schemas   = ["public", "auth"]
}
// .env: DATABASE_URL="file:./dev.db" （prisma フォルダ内に dev.db が作られます）
// 퀴즈앱과 같은 PostgreSQL: provider を "postgresql" に変更し DATABASE_URL を 퀴즈앱과 동일하게 설정

// ページ別の表データ（カリキュラム・料金表など）をJSONで保存
model SiteTable {
  id        String   @id @default(cuid())
  pageSlug  String   // kojin, group, kaiwa, special, syutyu, trial, book など
  blockKey  String   // curriculum_tanki, price_kojin など（ページ内で一意）
  title     String?  // 表示用: 初級, 中級, 上級 など
  rowsJson  String   // JSON: 行データの配列。例: [{ koma, c12, c24, c48, cellGreen?, cellComplete? }]
  updatedAt DateTime @updatedAt

  @@unique([pageSlug, blockKey])
  @@map("site_tables")
  @@schema("public")
}

// メインページのYouTube動画（SEO用・管理画面で編集）
model YouTubeVideo {
  id          String   @id @default(cuid())
  videoId     String   // YouTube動画ID（11文字）
  title       String
  category    String?  // 分類：生活韓国語、TOPIK初級、TOPIK中級、TOPIK上級、役に立つ韓国語
  description String?  // カード用短い説明
  seoSummary  String?  // SEO用：2〜3文の要約（検索エンジン向け）
  duration    String?  // ISO 8601形式（例: PT5M30S = 5分30秒）
  uploadDate  String?  // Schema.org用: YYYY-MM-DDTHH:mm:ss+09:00
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("youtube_videos")
  @@schema("public")
}

// 講座スケジュールのカテゴリ（管理画面で編集・追加可能）
model ScheduleCategory {
  id        String   @id @default(cuid())
  value     String   @unique // cat-tsushin など
  label     String   // 通信講座 など
  color     String   @default("#e5e7eb") // カレンダー表示用
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedule_categories")
  @@schema("public")
}

// 講座スケジュール（メインページカレンダー）
model ScheduleEvent {
  id                String   @id @default(cuid())
  eventType         String   // "recurring" | "single"
  label             String   // 講座名
  cat               String   // カテゴリvalue（ScheduleCategory.value）
  categoryLabel     String?  // 表示名オーバーライド（空ならカテゴリのlabelを使用）
  time              String?  // 表示用: 14:00〜, 随時受付中 など
  detail            String?  // ツールチップ・詳細
  url               String?  // リンク先: group.html#tab05 など
  dow               Int?     // 曜日 0-6 (recurring用)
  biweekly          Boolean  @default(false) // 隔週か
  biweeklyStartDate DateTime? // 隔週の基準日 (recurring用)
  monthlyWeeks      String?  // 毎月の週: "1,3"=1・3週, "2,4"=2・4週, null=毎週
  endDate           String?  // YYYY-MM-DD 終了日 (recurring用)
  date              String?  // YYYY-MM-DD (single用)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("schedule_events")
  @@schema("public")
}

// 講座スケジュールの公開スナップショット（管理画面「フロントに反映」で更新）
model SchedulePublished {
  id        String   @id @default("schedule")
  dataJson  String   // JSON: { recurring, single, categories }
  updatedAt DateTime @updatedAt

  @@map("schedule_published")
  @@schema("public")
}

// カリキュラムの公開スナップショット（管理画面「フロントに反映」で更新）
// id: curriculum_kojin, curriculum_group, curriculum_kaiwa, curriculum_special, themes_kojin
model CurriculumPublished {
  id        String   @id
  dataJson  String   // JSON: blocks[] or themes[]
  updatedAt DateTime @updatedAt

  @@map("curriculum_published")
  @@schema("public")
}

// --- Admin auth (sessions + OTP challenges; additive only) ---

model AdminSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("admin_sessions")
  @@schema("public")
}

model AdminOtpChallenge {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  otpHash   String
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("admin_otp_challenges")
  @@schema("public")
}

model RateLimitBucket {
  id        String   @id @default(cuid())
  key       String
  windowKey Int
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, windowKey], name: "rate_limit_key_window")
  @@map("rate_limit_buckets")
  @@schema("public")
}

// --- Newsletter module (isolated; additive only) ---

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  status         String    @default("pending")
  source         String    @default("web")
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  bouncedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tokens     NewsletterSubscriptionToken[]
  deliveries NewsletterCampaignDelivery[]

  @@map("newsletter_subscribers")
  @@schema("public")
}

model NewsletterSubscriptionToken {
  id           String  @id @default(cuid())
  subscriberId String?
  email        String
  tokenHash    String  @unique
  purpose      String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime @default(now())

  subscriber NewsletterSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("newsletter_subscription_tokens")
  @@schema("public")
}

model NewsletterCampaign {
  id               String    @id @default(cuid())
  subject          String
  preheader        String?
  bodyHtml         String    @db.Text
  ctaLabel         String?
  ctaUrl           String?
  status           String    @default("draft")
  scheduledAt      DateTime?
  sentAt           DateTime?
  totalTargetCount Int       @default(0)
  sentCount        Int       @default(0)
  failedCount      Int       @default(0)
  openCount        Int       @default(0)
  uniqueOpenCount  Int       @default(0)
  clickCount       Int       @default(0)
  uniqueClickCount Int       @default(0)
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  deliveries NewsletterCampaignDelivery[]

  @@index([status, scheduledAt])
  @@map("newsletter_campaigns")
  @@schema("public")
}

model NewsletterCampaignDelivery {
  id              String    @id @default(cuid())
  campaignId      String
  subscriberId    String?
  email           String
  resendMessageId String?
  deliveryStatus  String    @default("queued")
  errorMessage    String?
  sentAt          DateTime?
  firstOpenedAt   DateTime?
  firstClickedAt  DateTime?
  openCount       Int       @default(0)
  clickCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campaign   NewsletterCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriber NewsletterSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([campaignId, deliveryStatus])
  @@index([email])
  @@map("newsletter_campaign_deliveries")
  @@schema("public")
}

model NewsletterImportJob {
  id               String   @id @default(cuid())
  originalFilename String
  totalRows        Int      @default(0)
  insertedRows     Int      @default(0)
  updatedRows      Int      @default(0)
  skippedRows      Int      @default(0)
  invalidRows      Int      @default(0)
  createdBy        String?
  createdAt        DateTime @default(now())

  rows NewsletterImportJobRow[]

  @@map("newsletter_import_jobs")
  @@schema("public")
}

model NewsletterImportJobRow {
  id              String   @id @default(cuid())
  importJobId     String
  rawEmail        String
  normalizedEmail String?
  resultType      String
  message         String?
  createdAt       DateTime @default(now())

  importJob NewsletterImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("newsletter_import_job_rows")
  @@schema("public")
}
