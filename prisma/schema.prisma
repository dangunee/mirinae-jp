// ミリネ管理画面：ホームページの表データ（個人・グループ等）
// 퀴즈앱과 같은 DB를 쓰려면 .env에 DATABASE_URL을 퀴즈앱과 동일하게 설정하세요.
// 예: DATABASE_URL="postgresql://user:pass@host:5432/dbname"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// .env: DATABASE_URL="file:./dev.db" （prisma フォルダ内に dev.db が作られます）
// 퀴즈앱과 같은 PostgreSQL: provider を "postgresql" に変更し DATABASE_URL を 퀴즈앱과 동일하게 설정

// ページ別の表データ（カリキュラム・料金表など）をJSONで保存
model SiteTable {
  id        String   @id @default(cuid())
  pageSlug  String   // kojin, group, kaiwa, special, syutyu, trial, book など
  blockKey  String   // curriculum_tanki, price_kojin など（ページ内で一意）
  title     String?  // 表示用: 初級, 中級, 上級 など
  rowsJson  String   // JSON: 行データの配列。例: [{ koma, c12, c24, c48, cellGreen?, cellComplete? }]
  updatedAt DateTime @updatedAt

  @@unique([pageSlug, blockKey])
  @@map("site_tables")
}

// 会話強化クラス：レベル別カリキュラム（初中級・中級1・中級2・上級）
model KaiwaCurriculum {
  id        String   @id @default(cuid())
  levelKey  String   // shochukyu, chukyu1, chukyu2, jokyu
  rowOrder  Int      // 行の並び順（1, 2, 3...）
  theme     String   // テーマ例（例：初対面の挨拶、自己紹介）
  updatedAt DateTime @updatedAt

  @@unique([levelKey, rowOrder])
  @@map("kaiwa_curriculum")
}

// メインページのYouTube動画（SEO用・管理画面で編集）
model YouTubeVideo {
  id          String   @id @default(cuid())
  videoId     String   // YouTube動画ID（11文字）
  title       String
  category    String?  // 分類：生活韓国語、TOPIK初級、TOPIK中級、TOPIK上級、役に立つ韓国語
  description String?  // カード用短い説明
  seoSummary  String?  // SEO用：2〜3文の要約（検索エンジン向け）
  duration    String?  // ISO 8601形式（例: PT5M30S = 5分30秒）
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("youtube_videos")
}
