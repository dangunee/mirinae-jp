{
  "redirects": [
    { "source": "/b", "destination": "/b/", "permanent": true },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.mirinae.jp" }],
      "destination": "https://mirinae.jp/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:path*",
      "destination": "https://old.mirinae.jp/blog/:path*"
    },
    {
      "source": "/wordpress/:path*",
      "destination": "https://old.mirinae.jp/wordpress/:path*"
    }
  ]
}
